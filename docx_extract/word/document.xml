<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mo="http://schemas.microsoft.com/office/mac/office/2008/main" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:mv="urn:schemas-microsoft-com:mac:vml" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 wp14"><w:body><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>Product Requirements Document (PRD)</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Multi-Tenant AI Voice Agent SaaS Platform</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>1. Product Overview</w:t></w:r></w:p><w:p><w:r><w:t>Build a multi-tenant SaaS platform that allows businesses to create AI voice and text agents trained on their website content using RAG (Retrieval-Augmented Generation).</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>2. Product Goals</w:t></w:r></w:p><w:p><w:r><w:t>- Allow AI deployment on any website</w:t><w:br/><w:t>- Support multiple clients securely</w:t><w:br/><w:t>- Provide real-time voice and text AI conversations</w:t><w:br/><w:t>- Use website-specific knowledge only</w:t><w:br/><w:t>- Provide analytics and monitoring</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>3. Core Features</w:t></w:r></w:p><w:p><w:r><w:t>- Website training using crawler and embeddings</w:t><w:br/><w:t>- Voice + text AI chat</w:t><w:br/><w:t>- Embeddable widget</w:t><w:br/><w:t>- Analytics dashboard</w:t><w:br/><w:t>- Real-time WebSocket streaming</w:t><w:br/><w:t>- Multi-tenant isolation</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>4. Technology Stack</w:t></w:r></w:p><w:p><w:r><w:t>Frontend: Next.js</w:t><w:br/><w:t>Backend: FastAPI</w:t><w:br/><w:t>Database &amp; Authentication: Supabase</w:t><w:br/><w:t>Cache: Redis</w:t><w:br/><w:t>Vector Database: Qdrant</w:t><w:br/><w:t>LLM: Groq API</w:t><w:br/><w:t>Website Crawling: Playwright + BeautifulSoup</w:t><w:br/><w:t>Speech-to-Text: Deepgram</w:t><w:br/><w:t>Text-to-Speech: ElevenLabs</w:t><w:br/><w:t>Real-Time Communication: WebSockets</w:t><w:br/><w:t>Deployment: Docker</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>5. Version Control Workflow</w:t></w:r></w:p><w:p><w:r><w:t>Use Git and GitHub from project start to deployment.</w:t><w:br/><w:br/><w:t>Workflow:</w:t><w:br/><w:t>1. Initialize Git repository</w:t><w:br/><w:t>2. Create feature branches</w:t><w:br/><w:t>3. Commit changes regularly</w:t><w:br/><w:t>4. Push code to GitHub</w:t><w:br/><w:t>5. Create pull requests</w:t><w:br/><w:t>6. Merge reviewed code</w:t><w:br/><w:t>7. Maintain release tags and versions</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>6. System Architecture</w:t></w:r></w:p><w:p><w:r><w:t>Client Website → AI Widget → WebSocket → FastAPI Backend → Groq API → RAG Engine → Qdrant Vector Database → Website Knowledge</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>7. Functional Requirements</w:t></w:r></w:p><w:p><w:r><w:t>- Website crawling</w:t><w:br/><w:t>- RAG retrieval</w:t><w:br/><w:t>- Voice processing</w:t><w:br/><w:t>- Real-time streaming</w:t><w:br/><w:t>- Widget SDK</w:t><w:br/><w:t>- Dashboard analytics</w:t><w:br/><w:t>- Multi-tenant support</w:t><w:br/><w:t>- Authentication using Supabase</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>8. Non-Functional Requirements</w:t></w:r></w:p><w:p><w:r><w:t>- Low latency responses</w:t><w:br/><w:t>- Secure authentication</w:t><w:br/><w:t>- Scalable architecture</w:t><w:br/><w:t>- Concurrent WebSocket support</w:t><w:br/><w:t>- Data isolation using client_id</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>9. Database Structure</w:t></w:r></w:p><w:p><w:r><w:t>Supabase PostgreSQL Tables:</w:t><w:br/><w:t>clients</w:t><w:br/><w:t>conversations</w:t><w:br/><w:t>analytics</w:t><w:br/><w:t>training_jobs</w:t><w:br/><w:t>api_keys</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>10. Development Workflow</w:t></w:r></w:p><w:p><w:r><w:t>Phase 1: Setup Git + GitHub repository</w:t><w:br/><w:t>Phase 2: Build FastAPI backend</w:t><w:br/><w:t>Phase 3: Setup Supabase database and authentication</w:t><w:br/><w:t>Phase 4: Integrate Groq API</w:t><w:br/><w:t>Phase 5: Build website crawler</w:t><w:br/><w:t>Phase 6: Build RAG pipeline</w:t><w:br/><w:t>Phase 7: Add voice AI</w:t><w:br/><w:t>Phase 8: Build widget SDK</w:t><w:br/><w:t>Phase 9: Build dashboard</w:t><w:br/><w:t>Phase 10: Deploy using Docker</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>11. Final Deliverables</w:t></w:r></w:p><w:p><w:r><w:t>- AI Voice Agent</w:t><w:br/><w:t>- Dashboard</w:t><w:br/><w:t>- Embeddable widget</w:t><w:br/><w:t>- Real-time voice system</w:t><w:br/><w:t>- RAG engine</w:t><w:br/><w:t>- Multi-tenant SaaS platform</w:t><w:br/><w:t>- GitHub repository with version control</w:t></w:r></w:p><w:sectPr w:rsidR="00FC693F" w:rsidRPr="0006063C" w:rsidSect="00034616"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1800" w:bottom="1440" w:left="1800" w:header="720" w:footer="720" w:gutter="0"/><w:cols w:space="720"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>